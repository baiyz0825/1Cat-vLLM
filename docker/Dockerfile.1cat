# 1Cat-vLLM Docker Image (prebuilt wheel approach)
#
# Uses official release wheels — no CUDA compilation needed.
# Builds successfully on GitHub Actions without GPU.
#
# Build:
#   DOCKER_BUILDKIT=1 docker build . \
#     --tag ghcr.io/baiyz0825/1Cat-vLLM:1.0.0 \
#     --file docker/Dockerfile.1cat
#
# Ref: https://github.com/1CatAI/1Cat-vLLM/releases/tag/v1.0.0

FROM python:3.12-slim-trixie

ARG CUDA_VERSION=12.8
ARG FLASH_ATTN_V100_WHEEL="https://github.com/1CatAI/1Cat-vLLM/releases/download/v1.0.0/flash_attn_v100-1.0.0-cp312-cp312-linux_x86_64.whl"
ARG VLLM_WHEEL="https://github.com/1CatAI/1Cat-vLLM/releases/download/v1.0.0/vllm-1.0.0-cp312-cp312-linux_x86_64.whl"

# gcc/g++ needed for Triton first-run JIT compilation
RUN apt-get update -y && \
    apt-get install -y --no-install-recommends \
        build-essential \
        wget \
    && rm -rf /var/lib/apt/lists/*

# Install PyTorch + both wheels in one layer
RUN pip install --no-cache-dir --prefer-binary \
        --extra-index-url https://download.pytorch.org/whl/cu128 \
        "${FLASH_ATTN_V100_WHEEL}" \
        "${VLLM_WHEEL}" \
    && python -c "import vllm; print('vllm', vllm.__version__)" \
    && python -c "import flash_attn_v100; print('flash_attn_v100 OK')"

# Expose default vLLM port
EXPOSE 8000

# Default entrypoint — GPUStack overrides both ENTRYPOINT and CMD
ENTRYPOINT ["vllm"]
